<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <!-- Logs Directory -->
    <property name="LOG_DIR" value="logs"/>

    <!-- Console Pattern -->
    <property name="CONSOLE_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%thread] [%X{testId}] %logger{36} - %msg%n"/>

    <!-- File Pattern -->
    <property name="FILE_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%thread] [%X{testId}] %logger{36} - %msg%n"/>

    <!-- Console Appender -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Rolling File Appender -->
    <appender name="FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_DIR}/automation.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <!-- Daily rollover -->
            <fileNamePattern>
                ${LOG_DIR}/archived/automation.%d{yyyy-MM-dd}.%i.log
            </fileNamePattern>

            <!-- 10MB per file -->
            <maxFileSize>10MB</maxFileSize>

            <!-- Keep 30 days -->
            <maxHistory>30</maxHistory>

            <!-- Total cap -->
            <totalSizeCap>2GB</totalSizeCap>

        </rollingPolicy>

        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>

    </appender>
    
    <!-- Your framework logs -->
    <logger name="com.amalw" level="DEBUG"/>

    <!-- Selenium Logs Reduction -->
    <logger name="org.openqa.selenium" level="WARN"/>
    <logger name="io.github.bonigarcia" level="INFO"/>
    <logger name="org.apache.hc" level="WARN"/>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>